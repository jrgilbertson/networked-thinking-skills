# Generated from validated audit JSONL. This Base is a derived triage view, not source of truth.
formulas:
  source_jsonl: '"tests/golden/fixture-audit.jsonl"'
properties:
  formula.source_jsonl:
    displayName: "Source JSONL"
  file.path:
    displayName: "Note Path"
views:
  - type: table
    name: "All Audited Notes"
    filters:
      or:
        - 'file.path == "Atomic Notes/202601010101 Clean DAE note.md"'
        - 'file.path == "Atomic Notes/202601010102 Weak DAE note.md"'
        - 'file.path == "Atomic Notes/202601010103 Multi note bundle.md"'
        - 'file.path == "Atomic Notes/202601010104 Misfiled reference note.md"'
        - 'file.path == "Atomic Notes/202601010105 Missing parent note.md"'
        - 'file.path == "Atomic Notes/202601010106 Factual risk note.md"'
        - 'file.path == "Atomic Notes/202601010107 Optional Anki note.md"'
        - 'file.path == "Atomic Notes/202601010108 Malformed Anki note.md"'
        - 'file.path == "Atomic Notes/202601010109 Duplicate candidate note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "P0 Critical"
    filters:
      and:
        - 'file.path == "Atomic Notes/202601010103 Multi note bundle.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "P1 High Impact"
    filters:
      or:
        - 'file.path == "Atomic Notes/202601010102 Weak DAE note.md"'
        - 'file.path == "Atomic Notes/202601010104 Misfiled reference note.md"'
        - 'file.path == "Atomic Notes/202601010105 Missing parent note.md"'
        - 'file.path == "Atomic Notes/202601010106 Factual risk note.md"'
        - 'file.path == "Atomic Notes/202601010108 Malformed Anki note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "P2 Improvements"
    filters:
      and:
        - 'file.path == "Atomic Notes/202601010109 Duplicate candidate note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "P3 Polish"
    filters:
      or:
        - 'file.path == "Atomic Notes/202601010101 Clean DAE note.md"'
        - 'file.path == "Atomic Notes/202601010107 Optional Anki note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "Clean Notes"
    filters:
      or:
        - 'file.path == "Atomic Notes/202601010101 Clean DAE note.md"'
        - 'file.path == "Atomic Notes/202601010107 Optional Anki note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "Factual Risk"
    filters:
      and:
        - 'file.path == "Atomic Notes/202601010106 Factual risk note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "Multi-Note Split Candidates"
    filters:
      and:
        - 'file.path == "Atomic Notes/202601010103 Multi note bundle.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "Missing Parent Candidates"
    filters:
      or:
        - 'file.path == "Atomic Notes/202601010102 Weak DAE note.md"'
        - 'file.path == "Atomic Notes/202601010103 Multi note bundle.md"'
        - 'file.path == "Atomic Notes/202601010104 Misfiled reference note.md"'
        - 'file.path == "Atomic Notes/202601010105 Missing parent note.md"'
        - 'file.path == "Atomic Notes/202601010106 Factual risk note.md"'
        - 'file.path == "Atomic Notes/202601010108 Malformed Anki note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
  - type: table
    name: "Duplicate Or Overlap Candidates"
    filters:
      and:
        - 'file.path == "Atomic Notes/202601010109 Duplicate candidate note.md"'
    order:
      - file.name
      - file.path
      - formula.source_jsonl
